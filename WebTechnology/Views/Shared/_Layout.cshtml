<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JewelryShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebTechnology.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3" style="background-color: #EBDFCE;">
            <div class="container-fluid" style="position: relative; display: flex; align-items: center;">

                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Products" asp-action="Index">Каталог</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Политика</a>
                        </li>
                    </ul>
                </div>

                <div style="position: absolute; left: 50%; transform: translateX(-50%);">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">JewelryShop</a>
                </div>

                <div style="margin-left: auto; display: flex; align-items: center; gap: 10px;">
                    <a href="/Cart" style="display: inline-block;">
                        <img src="~/images/cart.svg" alt="Корзина" style="width: 35px; height: 35px;">
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </div>
        </nav>
    </header>
    <div style="margin: 0; padding: 0; width: 100%; max-width: 100%;">
        <main role="main" style="margin: 0; padding: 0;">
            @RenderBody()
        </main>
    </div>

    <footer style="text-align: center; padding: 5px 0; font-size: 12px; color: gray; background-color: #EBDFCE;">
        &copy; Ювелирный магазин | <a asp-controller="Home" asp-action="Privacy">Политика</a>
    </footer>
</body>
</html>