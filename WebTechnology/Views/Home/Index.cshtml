@{
    ViewData["Title"] = "Ювелириные изделия";
}
<div style="display: flex; margin: 0; padding: 0;">
    <div style="flex: 1; margin: 0; padding: 0;">
        <img src="~/images/jewelry1.jpg" style="width: 100%; height: 500;object-fit: cover; display: block;">
    </div>
    <div style="flex: 1; margin: 0; padding: 0;">
        <img src="~/images/jewelry2.jpg" style="width: 100%; height: 500; object-fit: cover; display: block;">
    </div>
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
        <p style="font-size: 60px; margin: 0;">ELEGANT JEWELRY</p>
        <a href="/Products" style="display: inline-block; background: transparent; color: white; padding: 10px 35px; text-decoration: none; border-radius: 30px; font-size: 16px; border: 1px solid white; margin-top: 15px;">К каталогу</a>
    </div>
</div>